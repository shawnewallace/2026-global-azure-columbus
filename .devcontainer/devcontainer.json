{
  "name": "Global Azure Columbus 2026 — Demo Environment",
  // Docker Compose: app (.NET 10) + db (PostgreSQL 16) + aspire-dashboard (Azurite removed — no longer needed)
  "dockerComposeFile": "docker-compose.yml",
  "service": "app",
  "workspaceFolder": "/workspaces/${localWorkspaceFolderBasename}",
  "features": {
    // Node.js 22 LTS — required for npx-based MCP servers
    "ghcr.io/devcontainers/features/node:1": {
      "version": "22"
    },
    // Azure CLI
    "ghcr.io/devcontainers/features/azure-cli:1": {
      "version": "latest"
    },
    // GitHub CLI — for coding agent workflows and repo operations
    "ghcr.io/devcontainers/features/github-cli:1": {
      "version": "latest"
    }
  },
  "customizations": {
    "vscode": {
      "extensions": [
        // GitHub Copilot
        "GitHub.copilot",
        "GitHub.copilot-chat",
        // C# / .NET
        "ms-dotnettools.csdevkit",
        "ms-dotnettools.csharp",
        // Azure MCP Server + Azure Skills (one install, brain + hands)
        "ms-azuretools.vscode-azure-mcp-server",
        // Azure Developer CLI (azd) — deploy workflows
        "ms-azuretools.azure-dev",
        // Azure resource browsing
        "ms-azuretools.vscode-azureresourcegroups",
        // GitHub Actions — watch the coding agent's Actions runs live
        "GitHub.vscode-github-actions",
        "bierner.markdown-mermaid",
        "ms-azuretools.vscode-azurestaticwebapps",
        "ms-azuretools.vscode-bicep"
      ],
      "settings": {
        "github.copilot.enable": {
          "*": true
        },
        "dotnet.defaultSolution": "disable",
        "editor.formatOnSave": true,
        "editor.inlineSuggest.enabled": true
      }
    }
  },
  "postCreateCommand": "bash .devcontainer/postCreate.sh",
  // Start the React dev server and Azure Functions API every time the container starts.
  // Web deps and the .NET build are pre-warmed in postCreate, so these start quickly.
  "postStartCommand": "(cd /workspaces/${localWorkspaceFolderBasename}/src/web && npm run dev) & (cd /workspaces/${localWorkspaceFolderBasename}/src/api/src/TaskLibrary.Api && dotnet run) &",
  "forwardPorts": [
    5173,
    5432,
    8080,
    18888,
    18889
  ],
  "portsAttributes": {
    "5173": {
      "label": "React Dev Server (Vite)",
      "onAutoForward": "openBrowser"
    },
    "5432": {
      "label": "PostgreSQL"
    },
    "8080": {
      "label": "API (ASP.NET Core)",
      "onAutoForward": "notify"
    },
    "18888": {
      "label": "Aspire Dashboard"
    },
    "18889": {
      "label": "OTLP gRPC"
    }
  },
  "remoteUser": "vscode"
}